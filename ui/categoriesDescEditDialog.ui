  <property name="styleSheet">
   <string notr="true">* {
	color: #111;
	font-family: &quot;Futura&quot;, &quot;Verdana&quot;, &quot;Sans-Serif&quot;;
	font-size: 14px;
}


QMenu {
	background-color: #fff;
	color: #111;
	font-size: 14px;
}


QDialog {
	background-color: #e0e1dd;
}


#central_widget {
	background-color: #fff;
	padding: 5px 3px;
	border-radius: 10px;
	margin-bottom: 5px;
}


QToolTip {
	background-color: #fff;
	color: #0d1b2a;
}


/* textedit */
QTextEdit {
	background-color: #e0e1dd;
	selection-background-color: #3b66ab;
	selection-color: #fff;
	border-radius: 10px;
	padding-left: 3px;
	padding-right: 3px;
}


/* label */
QLabel {
	background-color: #fff;
}


/* pushbuttons */
QPushButton[text='Guardar'] {
	background-color: #415a77;
	color: #fff;
	border: none;
}

QPushButton[text='Descartar'] {
	background-color: #fff;
	color: #111;
	border: 1px solid #111;
}

QPushButton {
	border-radius: 4px;
	width: 150px;
	height: 25px;
}
QPushButton:hover,
QPushButton:focus {
	background-color: #3b66ab;
}
QPushButton:pressed {
	background-color: #3b66ab;
	border: 1px inset #778da9;
}
QPushButton:disabled {
	background-color: rgb(103, 115, 122);
	color: #999;
}


/* scrollbars */
QScrollBar {
	background-color: #e0e1dd;
	border: 1px solid transparent;
	border-radius: 5px;
}
QScrollBar:groove {
	border-radius: 5px;
}
QScrollBar::handle {
	background-color:  #1b263b;
	border-radius: 5px;
}
QScrollBar::handle:pressed {
	background-color: #3b465b;
}
QScrollBar::sub-line {
	width: 0;
	height: 0;
	background: none;
}
QScrollBar::add-line {
	width: 0;
	height: 0;
	background: none;
}


/*vertical scrollbars*/
QScrollBar:vertical {
	width: 13px;
}
QScrollBar::handle:vertical {
	min-height: 15px;
}
QScrollBar::sub-page:vertical {
	background: none;
}
QScrollBar::add-page:vertical {
	background: none;
}

/*horizontal scrollbars*/
QScrollBar:horizontal {
	height: 13px;
}
QScrollBar::handle:horizontal {
	min-width: 15px;
}</string>
