/* checkbox */
QCheckBox {
	margin-top: 5px;
	padding: 0 3px;
	spacing: 5px;
    border: none;
	border-radius: 3px;
}
QCheckBox:hover,
QCheckBox:focus {
	background-color: #3b66ab;
}
QCheckBox:checked {
	background-color: #3b66ab;
    border: 1px inset #778da9;
}
QCheckBox:disabled {
	background-color: rgb(103, 115, 122);
    color: #999;
}


/* listtable y header */
QListWidget {
	color: #0d1b2a;
	background-color: #fff;
	border: None;
	border-radius: 10px;
}
QListWidget::item:hover {
	background-color: #778da9;
}
QListWidget::item:selected {
	background-color: #778da9;
	border: 1px solid #fff;
}
/* QHeaderView */
QHeaderView::section {
	background-color: #778da9;
	color: #fff;
	border: none;
	border-right: 1px solid;
	border-bottom: 1px solid;
	border-color: #e0e1dd;
}


/* scrollbars */
QScrollBar {
	background-color: #e0e1dd;
	border: 1px solid transparent;
	border-radius: 5px;
}
QScrollBar:groove {
	border-radius: 5px;
}
QScrollBar::handle {
	background-color:  #1b263b;
	border-radius: 5px;
}
QScrollBar::handle:pressed {
	background-color: #3b465b;
}
QScrollBar::sub-line {
	width: 0;
	height: 0;
	background: none;
}
QScrollBar::add-line {
	width: 0;
	height: 0;
	background: none;
}


/*vertical scrollbars*/
QScrollBar:vertical {
	width: 13px;
}
QScrollBar::handle:vertical {
	min-height: 15px;
}
QScrollBar::sub-page:vertical {
	background: none;
}
QScrollBar::add-page:vertical {
	background: none;
}</string>
